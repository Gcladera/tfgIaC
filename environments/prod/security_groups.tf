resource "aws_security_group" "grafana_sg" {
  name        = "GrafanaSG"
  description = "Allow access from my home"
  vpc_id      = "vpc-060d4d3da00079625"

  ingress {
    from_port   = 3000
    to_port     = 3000
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "efs_grafana" {
  description            = "allowc ecs access to efs"
}

resource "aws_security_group" "grafana_sg_mainvpc" {
  name        = "GrafanaSG-mainvpc"
  description = "Allow access from my home"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port   = 3000
    to_port     = 3000
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "efs_grafana_mainvpc" {
  name        = "efs-grafana-mainvpc"
  description = "allowc ecs access to efs"
  vpc_id      = module.vpc.vpc_id

  ingress {
    from_port       = 2049
    to_port         = 2049
    protocol        = "tcp"
    security_groups = [aws_security_group.grafana_sg_mainvpc.id]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "lambda-bronze" {
  name        = "lambda-bronze"
  description = "SG for bronze lambdas"
  vpc_id      = module.vpc.vpc_id
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_security_group" "lambda_silver_sg" {
  name        = "lambda-silver-sg"
  description = "Permite salida a la DB y servicios externos"
  vpc_id      = module.vpc.vpc_id
